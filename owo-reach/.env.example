# Monnify sandbox credentials — https://app.monnify.com → Developer → API Keys & Contracts
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=0000000000
# Your Monnify sandbox wallet account number (Dashboard → Wallet). Source of disbursements.
MONNIFY_SOURCE_ACCOUNT=9999999999

# AI provider for the chaos-ingestion + pre-flight-brief features.
# Provider-agnostic — pick whichever is cheapest, no code change needed.
#
# AI_PROVIDER: anthropic | openai | gemini | deepseek | kimi | openai-compatible
# AI_MODEL:    the provider's model id/slug (check their pricing page for the cheapest one)
# AI_API_KEY:  that provider's API key
# AI_BASE_URL: only needed for "openai-compatible" (a custom endpoint), or to
#              override a built-in preset (e.g. Moonshot's China domain)
#
# Examples — uncomment the vendor you're using. Model slugs drift as vendors
# deprecate old ones (e.g. Gemini retired 2.5-flash for new keys); if a model
# 404s, list what's actually available: curl -s <base>/models -H "Authorization: Bearer $AI_API_KEY"
#   AI_PROVIDER=anthropic   AI_MODEL=claude-sonnet-5
#   AI_PROVIDER=openai      AI_MODEL=gpt-5-mini
#   AI_PROVIDER=gemini      AI_MODEL=gemini-flash-latest
#   AI_PROVIDER=deepseek    AI_MODEL=deepseek-chat
#   AI_PROVIDER=kimi        AI_MODEL=kimi-k2
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-5
AI_API_KEY=sk-ant-xxxx
AI_BASE_URL=

PORT=3000
DATABASE_PATH=./data/owo.sqlite